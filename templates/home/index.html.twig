{% extends 'base.html.twig' %}

{% block title %}EcoRide - Accueil{% endblock %}

{% block body %}
    <section class="slogan-bloc d-flex align-items-center">
        <div class="overlay"></div>
        <div class="container text-center position-relative z-2">
            <h1 class="slogan-titre">Le covoiturage qui a du sens 🌿</h1>
            <p class="slogan-texte mt-3">EcoRide : Un trajet un geste pour demain.</p>
        </div>
    </section>

    <section class="accueil-structure my-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 mb-4 mb-md-0">
                    <img src="{{ asset('images/accueilecoride.jpg') }}" alt="EcoRide illustration" class="img-fluid rounded shadow">
                </div>
                <div class="col-md-6">
                    <h2 class="text-success mb-3">Pourquoi choisir EcoRide ?</h2>
                    <p>EcoRide est bien plus qu’un simple site de covoiturage. Nous vous connectons avec d’autres utilisateurs pour des trajets partagés, économiques et respectueux de l’environnement.</p>
                    <p>Grâce à notre approche responsable, chaque kilomètre compte pour la planète 🌍. Rejoignez notre communauté et adoptez une nouvelle manière de voyager.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="recherche-trajet">
        <div class="container">
            <h2 class="text-center mb-4">Trouvez votre trajet écologique</h2>
            <div class="card shadow">
                <div class="card-body">
                    <form method="get" action="{{ path('app_trajets') }}">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <input type="text" class="form-control" name="recherche_trajet[depart]" placeholder="Ville de départ" required>
                            </div>
                            <div class="col-md-3">
                                <input type="text" class="form-control" name="recherche_trajet[arrivee]" placeholder="Ville de destination" required>
                            </div>
                            <div class="col-md-3">
                                <input type="date" class="form-control" name="recherche_trajet[date]" min="{{ "now"|date('Y-m-d') }}" required>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary w-100">Rechercher</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section class="temoignages py-5 bg-light">
        <div class="container text-center">
            <h2 class="mb-4 text-success">Ils nous font confiance</h2>
            <div class="row justify-content-center">
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm p-3">
                        <div class="mb-3">
                            <img src="{{ asset('images/user1.jpg') }}" class="rounded-circle" width="60" alt="Client 1">
                        </div>
                        <p>"Un super service, pratique et économique. J’utilise EcoRide tous les jours pour aller au travail."</p>
                        <div class="text-warning">★★★★★</div>
                        <small class="text-muted">– Alice, Bordeaux</small>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm p-3">
                        <div class="mb-3">
                            <img src="{{ asset('images/user2.jpg') }}" class="rounded-circle" width="60" alt="Client 2">
                        </div>
                        <p>"C’est facile à utiliser, et j’ai rencontré des gens adorables sur mes trajets."</p>
                        <div class="text-warning">★★★★☆</div>
                        <small class="text-muted">– Marc, Lyon</small>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm p-3">
                        <div class="mb-3">
                            <img src="{{ asset('images/user3.jpg') }}" class="rounded-circle" width="60" alt="Client 3">
                        </div>
                        <p>"Enfin une plateforme qui pense à l’environnement. Merci EcoRide !"</p>
                        <div class="text-warning">★★★★★</div>
                        <small class="text-muted">– Sophie, Nantes</small>
                    </div>
                </div>
            </div>
        </div>
    </section>


{% endblock %}

