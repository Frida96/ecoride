{% extends 'base.html.twig' %}

{% block title %}Mon espace - EcoRide{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0">Bienvenue dans votre espace personnel</h2>
                </div>
                <div class="card-body">
                    <h3>Bonjour {{ app.user.nomComplet }}!</h3>
                    <p class="lead">Vous êtes connecté en tant qu'utilisateur.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Mes trajets</h5>
                                    <p class="card-text">Consultez les trajets que vous avez réservés ou publiés.</p>
                                    <a href="#" class="btn btn-outline-success">Voir mes trajets</a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Proposer un trajet</h5>
                                    <p class="card-text">Vous souhaitez partager votre prochain déplacement ?</p>
                                    <a href="#" class="btn btn-outline-success">Proposer un trajet</a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Mon profil</h5>
                                    <p class="card-text">Modifiez vos informations personnelles et vos préférences.</p>
                                    <a href="#" class="btn btn-outline-success">Gérer mon profil</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}