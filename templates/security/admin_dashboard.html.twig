{% extends 'base.html.twig' %}

{% block title %}Administration - EcoRide{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h2 class="mb-0">Panneau d'administration</h2>
                </div>
                <div class="card-body">
                    <h3>Bonjour {{ app.user.nomComplet }}!</h3>
                    <p class="lead">Vous êtes connecté en tant qu'administrateur.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Gestion des utilisateurs</h5>
                                    <p class="card-text">Ajoutez, modifiez ou supprimez des comptes utilisateurs.</p>
                                    <a href="{{ path('admin_users') }}" class="btn btn-outline-dark">Gérer</a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Configuration système</h5>
                                    <p class="card-text">Modifiez les paramètres globaux de l'application.</p>
                                    <a href="#" class="btn btn-outline-dark">Configurer</a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Logs et statistiques</h5>
                                    <p class="card-text">Consultez les logs et statistiques détaillées.</p>
                                    <a href="{{ path('admin_stats') }}" class="btn btn-outline-dark">Analyser</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="text-center mt-5">
                        <a href="{{ path('app_logout') }}" class="btn btn-danger">
                            <i class="fas fa-sign-out-alt me-2"></i>Se déconnecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}