{% extends 'base.html.twig' %}

{% block title %}Ajouter un véhicule - EcoRide{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h2 class="mb-0">Ajouter un véhicule</h2>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.marque) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.modele) }}
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.immatriculation) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.couleur) }}
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.places) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.energie) }}
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            {{ form_row(form.estEcologique) }}
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_user_vehicules') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Annuler
                            </a>
                            {{ form_row(form.submit) }}
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}