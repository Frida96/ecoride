{% extends 'base.html.twig' %}

{% block title %}Modifier un trajet - EcoRide{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Modifier un trajet</h2>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.depart) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.arrivee) }}
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                {{ form_row(form.date) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.heureDepart) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.heureArrivee) }}
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.places) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.prix) }}
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            {{ form_row(form.vehicule) }}
                        </div>
                        
                        <div class="mb-4">
                            {{ form_row(form.estEcologique) }}
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_user_trajets') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Annuler
                            </a>
                            {{ form_row(form.submit, {'label': 'Enregistrer les modifications'}) }}
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}